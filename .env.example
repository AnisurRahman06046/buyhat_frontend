# ──────────────────────────────────────────────────────────────────────────
# BuyHat Frontend — environment template. Copy to `.env.local` and adjust.
# ──────────────────────────────────────────────────────────────────────────

# Backend REST API base (client → backend for data fetching).
# Backend runs with global prefix `api` + URI version `v1`.
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Public origin of THIS frontend app (used in metadata, canonical URLs, OG).
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Brand / display name.
NEXT_PUBLIC_SITE_NAME=BuyHat

# Backend base used server-side by BFF route handlers (auth proxy) & SSR.
# Usually identical to NEXT_PUBLIC_API_URL in single-host setups; can point to
# an internal address in containerized deployments.
BACKEND_API_URL=http://localhost:3000/api/v1
